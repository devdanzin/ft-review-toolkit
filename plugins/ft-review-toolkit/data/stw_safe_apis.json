  "stw_contract": {
    "summary": "During _PyEval_StopTheWorld, all other threads are suspended at safe points. The calling thread has exclusive access to all Python objects. However, any operation that could re-enter the Python interpreter, trigger garbage collection, or set exceptions is unsafe because it may deadlock, corrupt interpreter state, or violate the assumption that no other code is running.",
    "rules": [
      "Do NOT call any Python/C API that could invoke Python code (__getattr__, __hash__, __eq__, __str__, etc.)",
      "Do NOT set exceptions (PyErr_*) — CPython's GC explicitly calls StartTheWorld before PyErr_NoMemory",
      "Do NOT allocate Python objects (PyList_New, PyDict_New, etc.) — may trigger GC which expects threads to be running",
      "Do NOT call _PyEval_StopTheWorld again (nested STW deadlocks)",
      "DO use direct struct access (Py_TYPE, PyTuple_GET_ITEM, etc.) for reading object state",
      "DO use Py_INCREF/Py_DECREF for reference counting",
      "DO use PyMem_Malloc/PyMem_Free for raw C memory allocation",
      "DO use _Py_atomic_* for atomic operations",
      "DO call _PyEval_StartTheWorld before returning to Python or reporting errors",
      "Pattern: StopTheWorld → traverse/read → StartTheWorld → process results/set errors/allocate"
    ],
    "cpython_evidence": {
      "gc_free_threading.c:2223": "_PyEval_StartTheWorld called BEFORE PyErr_NoMemory — exceptions unsafe during STW",
      "gc_free_threading.c:2253": "_PyEval_StartTheWorld called BEFORE cleanup_worklist/call_weakref_callbacks — Python code unsafe during STW",
      "gcmodule.c:287-289": "append_referrents runs during STW (reads only), result processing after StartTheWorld"
    }
  }
